DATABASE_ECHO=False

# 阿里云RDS MySQL (备用)
# DATABASE_URL=mysql+pymysql://root:Droi*#2018@rm-bp13737t91q29oa2c3o.mysql.rds.aliyuncs.com:3306/fof

# JWT配置
JWT_SECRET_KEY=fof-jwt-secret-key-2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置
CORS_ORIGINS=["*"]

# 文件上传
UPLOAD_DIR=./uploads
