# 舆情爬虫配置
# 默认禁用，因为数据源可能失效且会产生大量日志噪音
# 如需启用，设置为 true
ENABLE_SENTIMENT_CRAWLER=false
SENTIMENT_CRAWLER_INTERVAL=14400
