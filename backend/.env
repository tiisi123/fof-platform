# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# LLM 配置（DeepSeek OpenAI 兼容接口）
LLM_API_KEY=sk-44ce28c6423b42518deab0d0a0d69885
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_TIMEOUT=120
LLM_ENABLED=True

# AI Copilot 可选模型：OpenAI Codex 兼容接口
