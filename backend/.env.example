# 应用配置
APP_NAME=FOF管理平台
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=请修改为随机字符串

# 数据库配置 - 使用本地SQLite
DATABASE_URL=sqlite:///./fof.db
DATABASE_ECHO=False

# 阿里云RDS MySQL (备用)
# DATABASE_URL=mysql+pymysql://用户名:密码@数据库地址:3306/数据库名

# JWT配置
JWT_SECRET_KEY=请修改为随机字符串
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置
CORS_ORIGINS=["http://localhost:8507","http://你的服务器IP:8507"]

# 文件上传
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=100

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# LLM 配置（阿里云百炼 + DeepSeek）
LLM_API_KEY=你的API密钥
LLM_MODEL=deepseek-v3.2
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT=120
LLM_ENABLED=True

# 舆情爬虫配置
# 默认禁用，因为数据源可能失效且会产生大量日志噪音
# 如需启用，设置为 true
ENABLE_SENTIMENT_CRAWLER=false
SENTIMENT_CRAWLER_INTERVAL=14400
